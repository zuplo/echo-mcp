{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "echo-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-21",
  "workers_dev": false,
  "routes": [
    { "pattern": "mcp.echo.zuplo.io", "custom_domain": true }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
}
